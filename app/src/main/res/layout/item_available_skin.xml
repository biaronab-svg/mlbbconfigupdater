<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.HeroConfig.SkinCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <View
            android:id="@+id/sourceAccent"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@android:color/white"
            android:backgroundTint="?attr/colorSecondaryContainer"
            app:layout_constraintBottom_toBottomOf="@id/skeletonAvailableSkinLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/skeletonAvailableSkinLogo" />

        <ImageView
            android:id="@+id/imgSourceDragHandle"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginStart="10dp"
            android:alpha="0.55"
            android:background="?attr/colorSurfaceContainerHighest"
            android:contentDescription="@string/drag_to_reorder"
            android:padding="5dp"
            android:src="@drawable/ic_drag_handle"
            app:layout_constraintStart_toEndOf="@id/sourceAccent"
            app:layout_constraintTop_toTopOf="@id/skeletonAvailableSkinLogo"
            app:tint="?attr/colorOnSurfaceVariant" />

        <com.faltenreich.skeletonlayout.SkeletonLayout
            android:id="@+id/skeletonAvailableSkinLogo"
            android:layout_width="@dimen/available_skin_logo_size"
            android:layout_height="@dimen/available_skin_logo_size"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/imgSourceDragHandle"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgAvailableSkinLogo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/colorSurfaceContainerHighest"
                android:contentDescription="@string/skin_logo_desc"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.RoundedImage"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                tools:src="@tools:sample/avatars" />

        </com.faltenreich.skeletonlayout.SkeletonLayout>

        <LinearLayout
            android:id="@+id/actionContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditAvailableSkin"
                style="@style/Widget.HeroConfig.IconButton.Tonal"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:contentDescription="@string/edit_skin"
                app:icon="@drawable/ic_edit"
                app:iconSize="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoveAvailableSkin"
                style="@style/Widget.HeroConfig.IconButton.Outlined"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/delete_skin"
                app:icon="@drawable/ic_delete"
                app:iconSize="16dp"
                app:iconTint="?attr/colorError" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvAvailableSkinEyebrow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:text="@string/source_item_label"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="?attr/colorPrimary"
            app:layout_constraintEnd_toStartOf="@id/actionContainer"
            app:layout_constraintStart_toEndOf="@id/skeletonAvailableSkinLogo"
            app:layout_constraintTop_toTopOf="@id/skeletonAvailableSkinLogo" />

        <TextView
            android:id="@+id/tvAvailableSkinTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="12dp"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/actionContainer"
            app:layout_constraintStart_toStartOf="@id/tvAvailableSkinEyebrow"
            app:layout_constraintTop_toBottomOf="@id/tvAvailableSkinEyebrow"
            tools:text="Sasuke" />

        <TextView
            android:id="@+id/tvAvailableSkinMeta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintEnd_toStartOf="@id/actionContainer"
            app:layout_constraintStart_toStartOf="@id/tvAvailableSkinEyebrow"
            app:layout_constraintTop_toBottomOf="@id/tvAvailableSkinTitle"
            tools:text="drive.google.com" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAvailableSkinType"
            style="@style/Widget.HeroConfig.Chip.Tonal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/chip_text_size"
            tools:text="Naruto" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAvailableZip"
            style="@style/Widget.HeroConfig.Chip.Accent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/chip_text_size"
            tools:text="ZIP Ready" />

        <androidx.constraintlayout.helper.widget.Flow
            android:id="@+id/sourceChipFlow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:constraint_referenced_ids="chipAvailableSkinType,chipAvailableZip"
            app:flow_horizontalGap="@dimen/chip_spacing"
            app:flow_verticalGap="@dimen/chip_spacing"
            app:flow_wrapMode="chain"
            app:layout_constraintEnd_toStartOf="@id/actionContainer"
            app:layout_constraintStart_toStartOf="@id/tvAvailableSkinEyebrow"
            app:layout_constraintTop_toBottomOf="@id/tvAvailableSkinMeta" />

        <Space
            android:layout_width="0dp"
            android:layout_height="4dp"
            app:layout_constraintBottom_toBottomOf="@id/skeletonAvailableSkinLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/sourceChipFlow" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
