<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="?attr/colorSurface"
    app:cardElevation="0dp"
    app:shapeAppearanceOverlay="@style/ShapeAppearance.HeroConfig.Large">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="8dp">

        <View
            android:id="@+id/dragIndicator"
            android:layout_width="44dp"
            android:layout_height="4dp"
            android:alpha="0.7"
            android:background="?attr/colorOutlineVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnCloseUpgradeSheet"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="20dp"
            android:background="?attr/colorSurfaceContainerHighest"
            android:contentDescription="@string/close_sheet"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dragIndicator"
            app:tint="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/tvUpgradeSheetTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="12dp"
            android:text="Edit Upgrade Skin"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btnCloseUpgradeSheet"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dragIndicator" />

        <TextView
            android:id="@+id/tvUpgradeSheetSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="20dp"
            android:text="@string/upgrade_sheet_subtitle"
            android:textAppearance="@style/TextAppearance.HeroConfig.BodyMuted"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvUpgradeSheetTitle"
            app:layout_constraintTop_toBottomOf="@id/tvUpgradeSheetTitle" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/sheetScroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingBottom="104dp"
            app:layout_constraintBottom_toTopOf="@id/actionBar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvUpgradeSheetSubtitle">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/contentContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_max="@dimen/content_max_width">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardUpgradeDetails"
                        style="@style/Widget.HeroConfig.SectionCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="@dimen/section_card_padding">

                            <TextView
                                android:id="@+id/tvUpgradeLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/upgrade_sheet_info_title"
                                android:textAppearance="@style/TextAppearance.HeroConfig.SectionLabel"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tvUpgradeFieldHint"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/upgrade_sheet_info_subtitle"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/tvUpgradeLabel" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilUpgradeTitle"
                                style="@style/Widget.HeroConfig.TextInput"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:hint="@string/skin_title"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/tvUpgradeFieldHint">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etUpgradeSkinTitle"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content" />

                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilUpgradeType"
                                style="@style/Widget.HeroConfig.TextInput"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/field_spacing"
                                android:hint="@string/skin_type"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/tilUpgradeTitle">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etUpgradeSkinType"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content" />

                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilUpgradeLogo"
                                style="@style/Widget.HeroConfig.TextInput"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/field_spacing"
                                android:hint="@string/skin_logo_url"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/tilUpgradeType">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etUpgradeSkinLogo"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textUri" />

                            </com.google.android.material.textfield.TextInputLayout>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardSourceSection"
                        style="@style/Widget.HeroConfig.SectionCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/section_spacing"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/cardUpgradeDetails">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="@dimen/section_card_padding">

                            <TextView
                                android:id="@+id/tvSourceLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/source_skins_title"
                                android:textAppearance="@style/TextAppearance.HeroConfig.SectionLabel"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tvSourceSectionSubtitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:layout_marginEnd="12dp"
                                android:text="@string/source_skins_subtitle"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                app:layout_constraintEnd_toStartOf="@id/btnAddSourceSkin"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/tvSourceLabel" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAddSourceSkin"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="@string/add_source"
                                android:textSize="12sp"
                                app:icon="@drawable/ic_add"
                                app:iconSize="16dp"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipSourceCountSummary"
                                style="@style/Widget.HeroConfig.Chip.Accent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/tvSourceSectionSubtitle" />

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvSourceSkins"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:nestedScrollingEnabled="false"
                                android:overScrollMode="never"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/chipSourceCountSummary" />

                            <TextView
                                android:id="@+id/tvSourceSkinsEmpty"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:gravity="center"
                                android:paddingVertical="18dp"
                                android:text="@string/source_skins_empty"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:visibility="gone"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/rvSourceSkins" />

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardAddSource"
                                style="@style/Widget.HeroConfig.SurfaceCard"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:visibility="gone"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/tvSourceSkinsEmpty">

                                <androidx.constraintlayout.widget.ConstraintLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:padding="18dp">

                                    <TextView
                                        android:id="@+id/tvNewSourceLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/source_editor_title"
                                        android:textAppearance="@style/TextAppearance.HeroConfig.SectionLabel"
                                        app:layout_constraintStart_toStartOf="parent"
                                        app:layout_constraintTop_toTopOf="parent" />

                                    <TextView
                                        android:id="@+id/tvNewSourceSubtitle"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="@string/source_editor_subtitle"
                                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        app:layout_constraintEnd_toEndOf="parent"
                                        app:layout_constraintStart_toStartOf="parent"
                                        app:layout_constraintTop_toBottomOf="@id/tvNewSourceLabel" />

                                    <com.google.android.material.textfield.TextInputLayout
                                        android:id="@+id/tilSourceTitle"
                                        style="@style/Widget.HeroConfig.TextInput"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="16dp"
                                        android:hint="@string/skin_title"
                                        app:layout_constraintEnd_toEndOf="parent"
                                        app:layout_constraintStart_toStartOf="parent"
                                        app:layout_constraintTop_toBottomOf="@id/tvNewSourceSubtitle">

                                        <com.google.android.material.textfield.TextInputEditText
                                            android:id="@+id/etSourceSkinTitle"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content" />

                                    </com.google.android.material.textfield.TextInputLayout>

                                    <com.google.android.material.textfield.TextInputLayout
                                        android:id="@+id/tilSourceType"
                                        style="@style/Widget.HeroConfig.TextInput"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/field_spacing"
                                        android:hint="@string/skin_type"
                                        app:layout_constraintEnd_toEndOf="parent"
                                        app:layout_constraintStart_toStartOf="parent"
                                        app:layout_constraintTop_toBottomOf="@id/tilSourceTitle">

                                        <com.google.android.material.textfield.TextInputEditText
                                            android:id="@+id/etSourceSkinType"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content" />

                                    </com.google.android.material.textfield.TextInputLayout>

                                    <com.google.android.material.textfield.TextInputLayout
                                        android:id="@+id/tilSourceLogo"
                                        style="@style/Widget.HeroConfig.TextInput"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/field_spacing"
                                        android:hint="@string/skin_logo_url"
                                        app:layout_constraintEnd_toEndOf="parent"
                                        app:layout_constraintStart_toStartOf="parent"
                                        app:layout_constraintTop_toBottomOf="@id/tilSourceType">

                                        <com.google.android.material.textfield.TextInputEditText
                                            android:id="@+id/etSourceSkinLogo"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:inputType="textUri" />

                                    </com.google.android.material.textfield.TextInputLayout>

                                    <com.google.android.material.textfield.TextInputLayout
                                        android:id="@+id/tilSourceZip"
                                        style="@style/Widget.HeroConfig.TextInput"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/field_spacing"
                                        android:hint="@string/zip_url"
                                        app:layout_constraintEnd_toEndOf="parent"
                                        app:layout_constraintStart_toStartOf="parent"
                                        app:layout_constraintTop_toBottomOf="@id/tilSourceLogo">

                                        <com.google.android.material.textfield.TextInputEditText
                                            android:id="@+id/etSourceSkinZip"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:inputType="textUri" />

                                    </com.google.android.material.textfield.TextInputLayout>

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/btnCancelSource"
                                        style="@style/Widget.Material3.Button.TextButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="14dp"
                                        android:text="@string/cancel"
                                        app:layout_constraintEnd_toStartOf="@id/btnConfirmSource"
                                        app:layout_constraintTop_toBottomOf="@id/tilSourceZip" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/btnConfirmSource"
                                        style="@style/Widget.Material3.Button.TonalButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="@string/add"
                                        app:layout_constraintEnd_toEndOf="parent"
                                        app:layout_constraintTop_toTopOf="@id/btnCancelSource" />

                                </androidx.constraintlayout.widget.ConstraintLayout>

                            </com.google.android.material.card.MaterialCardView>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </com.google.android.material.card.MaterialCardView>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/actionBar"
            style="@style/Widget.HeroConfig.SurfaceCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal"
                android:padding="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelUpgradeSheet"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cancel" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveUpgradeSheet"
                    style="@style/Widget.HeroConfig.PrimaryButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/save" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
